# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB connection string. Locally: mongodb://localhost:27017
# On Render: use MongoDB Atlas free tier and paste its connection string here.
MONGO_URL="mongodb://localhost:27017"
DB_NAME="app_database"

# Comma-separated list of allowed frontend origins, e.g.
# CORS_ORIGINS="https://yourapp.com,http://localhost:3000"
CORS_ORIGINS="*"

# Generate a strong random secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="change-me-to-a-long-random-string"

# Bootstrap admin account, created automatically on first startup.
# Change the password immediately after your first login.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

APP_NAME="app"
ENV="development"

# Set to "true" once your site is served over HTTPS (Render gives you this by default)
COOKIE_SECURE="false"
