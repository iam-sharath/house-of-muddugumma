# Copy this file to .env for local development and set the real
# backend URL when deploying (e.g. as an environment variable in Render).

# Local dev default (your FastAPI backend running on port 8000):
REACT_APP_BACKEND_URL=http://localhost:8000

# Used only by `yarn start` (webpack-dev-server), not by production builds.
WDS_SOCKET_PORT=443
